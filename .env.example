# Open GENAI: docker compose 用の設定（コピーして .env として使用）

# ホストで Ollama を動かす場合（推奨, macOS は Metal GPU が使えて高速）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama もコンテナで動かす場合（docker compose --profile ollama up）は以下に変更
# OLLAMA_BASE_URL=http://ollama:11434

# LLM は OpenAI 互換 API 経由で呼び出します。
# 未指定なら OLLAMA_BASE_URL + /v1 を使用します。
# 以下に代表的な OpenAI 互換サーバーの設定例を示します（使用するものだけコメント解除）
#
# --- ローカル Ollama ---
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=ollama
#
# --- LM Studio (ローカル GUI でモデル管理) ---
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# OPENAI_API_KEY=lm-studio
#
# --- さくらインターネット AI クラウド (OpenAI 互換エンドポイント) ---
# https://cloud.sakura.ad.jp/specification/ai-cloud/
# OPENAI_BASE_URL=https://api.sakura.ai/v1
# OPENAI_API_KEY=<さくら AI API キー>
#
# --- Groq (超高速推論クラウド) ---
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=<Groq API キー>
#
# --- vLLM (オンプレ高スループット推論) ---
# OPENAI_BASE_URL=http://<vllm-host>:8000/v1
# OPENAI_API_KEY=token-xxxx
#
# --- OpenAI 公式 ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# --- LiteLLM Proxy / embedding_jp_api 連携設定（任意） ---
# クラウド (Gemini等) の API キーを指定
GEMINI_API_KEY=
# embedding_jp_api で利用する Hugging Face モデル名
# ruri-v3-30m: ModernBERT-Jaベース・30Mパラメータ・最大8192トークン対応・出力次元256
EMBED_MODEL_NAME=cl-nagoya/ruri-v3-30m

# 既定で利用するモデル（フロントでモデル未選択時に使用）
# LiteLLM 構成時は gemini-1.5-pro などを指定可能（docker-compose.yml 側で上書きされます）
DEFAULT_MODEL=gemma4

# --- RAG「AI アプリ」設定 ---
# 埋め込みモデル
# ★ LiteLLM の litellm_config.yaml で定義した model_name と完全一致させること
# ★ モデルを変更する際は EMBED_DIM も合わせて変更し、Qdrant コレクションを再作成すること
EMBED_MODEL=cl-nagoya/ruri-v3-30m
# Qdrant コレクションのベクトル次元
# ruri-v3-30m = 256 / ruri-v3-70m = 256 / ruri-v3-310m = 768
EMBED_DIM=256
# RAG 回答生成に使うモデル
RAG_MODEL=gemma4
# AI アプリ呼び出し用 API キー（ローカル任意値）
RAG_API_KEY=local-rag-key

# 日本語特化型 Embedding (ruri-v3) 用のプレフィックス設定
EMBED_QUERY_PREFIX=検索クエリ: 
EMBED_DOC_PREFIX=検索文書: 

# --- 文字起こし(Whisper) AI アプリ ---
# プロバイダの選択: local (faster-whisperによるローカル実行) または litellm (LiteLLMを中継してクラウド実行)
WHISPER_PROVIDER=local
# ローカル実行時のモデル設定
WHISPER_MODEL=medium        # small / medium / large-v3
WHISPER_COMPUTE=int8

# クラウド（LiteLLM）経由で実行する場合の設定
# LITELLM_AUDIO_MODEL の選択肢:
# - whisper-cloud    → OpenAI gpt-4o-transcribe（最新・高精度）
# - whisper-sakura   → さくらAI whisper-large-v3-turbo（国内完結）
# - whisper-azure    → Azure OpenAI Whisper
LITELLM_AUDIO_MODEL=whisper-cloud
LITELLM_AUDIO_URL=http://litellm:4000/v1
LITELLM_API_KEY=not-needed

# --- マルチプロバイダ API キー & エンドポイント設定 ---
# 使用するプロバイダのキーのみ設定すれば有効化されます（他は空欄で構いません）。
GEMINI_API_KEY=
OPENAI_API_KEY=
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
SAKURA_AI_API_KEY=
SAKURA_AI_API_BASE=https://api.ai.sakura.ad.jp/v1/



# --- 画像生成(Stable Diffusion) AI アプリ ---
# プロバイダの選択: local (A1111互換サーバー) または litellm (LiteLLM経由で GPT Image / Imagen 4 等)
IMAGE_PROVIDER=local
SD_API_URL=http://host.docker.internal:7860
LITELLM_IMAGE_MODEL=imagen-4
LITELLM_IMAGE_URL=http://litellm:4000/v1
LITELLM_IMAGE_API_KEY=not-needed

# --- Dify 連携 AI アプリ ---
# Dify(ワークフロー/チャットフロー)を「AI アプリ」として登録するための汎用プロキシ。
# アプリ登録時の endpoint に使う値（通常は変更不要）。
DIFY_APP_URL=http://dify-app:8004/invoke
# 既定の Dify 接続先(base_url, 末尾 /v1)。任意。
# 各 AI アプリの「設定(config)」で個別に指定する場合は空のままで構いません。
# 例: DIFY_BASE_URL=http://host.docker.internal/v1
# DIFY_BASE_URL=

# --- SAML 認証（backend = SAML SP / Keycloak = SAML IdP）---
# アプリ JWT 署名鍵（本番では十分長いランダム値に変更すること）
APP_JWT_SECRET=change-me-open-genai-secret
# ログイン後に戻るフロントエンド URL
FRONTEND_URL=http://localhost:5173
# Keycloak 管理者（http://localhost:8080 の admin console 用）
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- フロントエンドから見た API エンドポイント ---
# 別のホストやドメインで動かす場合は、localhost 部分をそのホスト名に書き換えてください。
VITE_APP_API_ENDPOINT=http://localhost:8000
VITE_APP_TEAM_ACCESS_CONTROL_API_ENDPOINT=http://localhost:8000

# Keycloak 自体の公開用ホスト名 URL
# 別のホストやドメインで動かす場合は、localhost 部分をそのホスト名に書き換えてください。
KEYCLOAK_HOSTNAME=http://localhost:8088

# --- 汎用 OpenAI 互換 (OpenAI Compatible) API 設定 ---
# 任意のOpenAI互換外部API（さくらAIやLM Studio等）を画面選択肢「openai-compatible-chat」で利用する際に設定します。
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_API_BASE=
OPENAI_COMPATIBLE_API_KEY=

# --- フロントエンドUI表示モデルの制御 ---
# 画面の選択肢に出したいモデル（LiteLLMに設定したキーが有効なもの）だけを配列で記述します。
# キーを設定していないプロバイダのモデルをここから除外すると、画面上の選択肢に表示されなくなります。
VITE_APP_MODEL_IDS=["gemini-2.5-pro","gemini-2.5-flash","sakura-gpt-oss-120b","sakura-qwen3-coder","openai-compatible-chat","gemma4"]

