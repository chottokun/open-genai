# Open GENAI: docker compose 用の設定（コピーして .env として使用）

# --- リバースプロキシ（ローカル/検証: HTTP のみ）---
# ブラウザからのアクセス URL（末尾スラッシュ無し）。PROXY_HTTP_PORT と合わせること。
PUBLIC_URL=http://localhost
# proxy がホストに公開する HTTP ポート（80 が使用中なら 8080 等に変更）
PROXY_HTTP_PORT=80

# ホストで Ollama を動かす場合（推奨, macOS は Metal GPU が使えて高速）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama もコンテナで動かす場合（docker compose --profile ollama up）は以下に変更
# OLLAMA_BASE_URL=http://ollama:11434

# LLM は OpenAI 互換 API 経由で呼び出します。
# 未指定なら OLLAMA_BASE_URL + /v1 を使用します。
# 以下に代表的な OpenAI 互換サーバーの設定例を示します（使用するものだけコメント解除）
#
# --- ローカル Ollama ---
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=ollama
#
# --- LM Studio (ローカル GUI でモデル管理) ---
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# OPENAI_API_KEY=lm-studio
#
# --- さくらインターネット AI クラウド (OpenAI 互換エンドポイント) ---
# https://cloud.sakura.ad.jp/specification/ai-cloud/
# OPENAI_BASE_URL=https://api.sakura.ai/v1
# OPENAI_API_KEY=<さくら AI API キー>
#
# --- Groq (超高速推論クラウド) ---
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=<Groq API キー>
#
# --- vLLM (オンプレ高スループット推論) ---
# OPENAI_BASE_URL=http://<vllm-host>:8000/v1
# OPENAI_API_KEY=token-xxxx
#
# --- OpenAI 公式 ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# --- クラウドAPI使用制御（課金・データ漏洩防止） ---
# true に設定した場合のみ、OpenAI / Gemini などの外部クラウド API の呼び出しを許可します。
# false（既定）の場合、意図しない外部課金やデータ送信を防ぐため、すべての外部API通信をブロックし、
# 強制的にローカルコンテナ/ローカルOllamaのみで完結させます。
ALLOW_CLOUD_API=false

# --- LiteLLM Proxy / embedding_jp_api 連携設定（任意） ---
# クラウド (Gemini等) の API キーを指定
GEMINI_API_KEY=
# embedding_jp_api で利用する Hugging Face モデル名
# ruri-v3-30m: ModernBERT-Jaベース・30Mパラメータ・最大8192トークン対応・出力次元256
EMBED_MODEL_NAME=cl-nagoya/ruri-v3-30m

# 既定で利用するモデル（フロントでモデル未選択時に使用）
# LiteLLM 構成時は gemini-1.5-pro などを指定可能（docker-compose.yml 側で上書きされます）
DEFAULT_MODEL=gemma4

# --- RAG「AI アプリ」設定 ---
# 埋め込みモデル
# ★ LiteLLM の litellm_config.yaml で定義した model_name と完全一致させること
# ★ モデルを変更する際は EMBED_DIM も合わせて変更し、Qdrant コレクションを再作成すること
EMBED_MODEL=cl-nagoya/ruri-v3-30m
# Qdrant コレクションのベクトル次元
# ruri-v3-30m = 256 / ruri-v3-70m = 256 / ruri-v3-310m = 768
EMBED_DIM=256
# RAG 回答生成に使うモデル
RAG_MODEL=gemma4
# AI アプリ呼び出し用 API キー（ローカル任意値）
RAG_API_KEY=local-rag-key

# 日本語特化型 Embedding (ruri-v3) 用のプレフィックス設定
EMBED_QUERY_PREFIX=検索クエリ: 
EMBED_DOC_PREFIX=検索文書: 

# ドキュメント取り込み時のバッチ分割および並行アクセス制限設定
# EMBED_BATCH_SIZE: 1回のリクエストに含める最大テキストチャンク数
# EMBED_MAX_CONCURRENCY: 埋め込みリクエストの最大並行数
EMBED_BATCH_SIZE=100
EMBED_MAX_CONCURRENCY=5

# --- 内部サービス間署名（x-user-* 偽装対策）---
# backend と全 exApp で同一値。空にすると検証を無効化（開発時のみ）。本番は必ず十分長い乱数に。
INTERNAL_SIGNING_SECRET=dev-internal-secret-change-me

# --- 成果物取得(SSRF 対策) ---
# 許可ホスト（カンマ区切り, 例: files.dify.ai）。空だと内部/プライベート宛先のみ拒否。
ARTIFACT_FETCH_ALLOWED_HOSTS=
# サーバが取得する成果物の最大サイズ（バイト。既定50MB）
ARTIFACT_MAX_BYTES=52428800
# RAG の URL 取り込み許可ホスト（カンマ区切り, 空=内部宛先のみ拒否）。行政ドメイン等に限定推奨
URL_FETCH_ALLOWED_HOSTS=

# --- 監査ログ参照(Audit) AI アプリ（管理者限定）---
# backend からのプロキシ先（通常は変更不要）
AUDIT_APP_URL=http://audit-app:8005/invoke

# --- 文字起こし(Whisper) AI アプリ ---
# プロバイダの選択:
# - local_api: 新設するローカル外出しAPIサーバーを使用 (推奨・GPU/CPU個別制御可能)
# - local: 既存のプロキシコンテナ内部で直接実行 (CPUのみ)
# - litellm: LiteLLMを中継して外部クラウドAPIを使用 (ALLOW_CLOUD_API=trueが必要)
WHISPER_PROVIDER=local_api
# WHISPER_PROVIDER=local_api 選択時の中継先URL
WHISPER_API_URL=http://local-whisper-api:8000/v1/audio/transcriptions

# ローカル実行時のモデル設定（WHISPER_PROVIDER=local 時のみ有効）
WHISPER_MODEL=medium        # small / medium / large-v3
WHISPER_COMPUTE=int8

# --- local-whisper-api (新コンテナ) 制御用（WHISPER_PROVIDER=local_api 時のみ有効） ---
# 実行デバイスの制御 (cpu または cuda)
AUDIO_INFERENCE_DEVICE=cpu
# 量子化・計算精度の制御 (int8, float16 など)
AUDIO_COMPUTE_TYPE=int8
# 使用する音声認識モデル（任意の Hugging Face 互換モデルを指定可能）
# - 日本語特化: kotoba-tech/kotoba-whisper-v1.0-faster
# - オリジナル Large v3: systran/faster-whisper-large-v3
# - オリジナル Medium: systran/faster-whisper-medium
# - オリジナル Small: systran/faster-whisper-small
AUDIO_MODEL_NAME=kotoba-tech/kotoba-whisper-v1.0-faster

# クラウド（LiteLLM）経由で実行する場合の設定
# LITELLM_AUDIO_MODEL の選択肢:
# - whisper-cloud    → OpenAI gpt-4o-transcribe（最新・高精度）
# - whisper-sakura   → さくらAI whisper-large-v3-turbo（国内完結）
# - whisper-azure    → Azure OpenAI Whisper
LITELLM_AUDIO_MODEL=whisper-cloud
LITELLM_AUDIO_URL=http://litellm:4000/v1
LITELLM_API_KEY=not-needed

# --- マルチプロバイダ API キー & エンドポイント設定 ---
# 使用するプロバイダのキーのみ設定すれば有効化されます（他は空欄で構いません）。
GEMINI_API_KEY=
OPENAI_API_KEY=
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
SAKURA_AI_API_KEY=
SAKURA_AI_API_BASE=https://api.ai.sakura.ad.jp/v1/



# --- 画像生成(Stable Diffusion) AI アプリ ---
# プロバイダの選択: local (A1111互換サーバー) または litellm (LiteLLM経由で GPT Image / Imagen 4 等)
IMAGE_PROVIDER=local
SD_API_URL=http://host.docker.internal:7860
LITELLM_IMAGE_MODEL=imagen-4
LITELLM_IMAGE_URL=http://litellm:4000/v1
LITELLM_IMAGE_API_KEY=not-needed

# --- 成果物ファイル配信用オブジェクトストレージ（自前 S3 互換: SeaweedFS）---
# AI アプリ（Dify等）が生成したファイルを自前ストレージへ再ホストし署名付きURLで配信。
# dev 既定は同梱の SeaweedFS。接続先を変えれば MinIO 等にも差し替え可能。
S3_ENDPOINT_URL=http://seaweedfs:8333
# 署名付きURL生成に使う公開エンドポイント（dev はホストから見える localhost:8333）
S3_PUBLIC_ENDPOINT=http://localhost:8333
S3_BUCKET=open-genai
# 認証情報（seaweedfs/s3.config.json と一致させること。本番は必ず変更）
S3_ACCESS_KEY=opengenai
S3_SECRET_KEY=opengenai-secret
# 署名付きURLの有効期限（秒。既定24時間）
S3_PRESIGN_EXPIRY=86400

# --- Dify 連携 AI アプリ ---
# Dify(ワークフロー/チャットフロー)を「AI アプリ」として登録するための汎用プロキシ。
# アプリ登録時の endpoint に使う値（通常は変更不要）。
DIFY_APP_URL=http://dify-app:8004/invoke
# 既定の Dify 接続先(base_url, 末尾 /v1)。任意。
# 各 AI アプリの「設定(config)」で個別に指定する場合は空のままで構いません。
# 例: DIFY_BASE_URL=http://host.docker.internal/v1
# DIFY_BASE_URL=

# --- SAML 認証（backend = SAML SP / Keycloak = SAML IdP）---
# アプリ JWT 署名鍵（本番では十分長いランダム値に変更すること）
APP_JWT_SECRET=change-me-open-genai-secret
# Keycloak 管理者（proxy 経由 http://localhost/kc/ の admin console 用）
# ※ 利用者一括管理(usermgmt-app) はこの管理者資格情報で Keycloak Admin API を呼ぶ
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# --- フロントエンドから見た API エンドポイント ---
# 別のホストやドメインで動かす場合は、localhost 部分をそのホスト名に書き換えてください。
VITE_APP_API_ENDPOINT=http://localhost:8000
VITE_APP_TEAM_ACCESS_CONTROL_API_ENDPOINT=http://localhost:8000

# Keycloak 自体の公開用ホスト名 URL
# 別のホストやドメインで動かす場合は、localhost 部分をそのホスト名に書き換えてください。
KEYCLOAK_HOSTNAME=http://localhost:8088

# --- 汎用 OpenAI 互換 (OpenAI Compatible) API 設定 ---
# 任意のOpenAI互換外部API（さくらAIやLM Studio等）を画面選択肢「openai-compatible-chat」で利用する際に設定します。
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_API_BASE=
OPENAI_COMPATIBLE_API_KEY=

# --- フロントエンドUI表示モデルの制御 ---
# 画面の選択肢に出したいモデル（LiteLLMに設定したキーが有効なもの）だけを配列で記述します。
# キーを設定していないプロバイダのモデルをここから除外すると、画面上の選択肢に表示されなくなります。
VITE_APP_MODEL_IDS=["gemini-2.5-pro","gemini-2.5-flash","sakura-gpt-oss-120b","sakura-qwen3-coder","openai-compatible-chat","gemma4"]

# usermgmt-app から見た Keycloak の内部URL（proxy 経由 /kc）
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080/kc
KEYCLOAK_REALM=open-genai

# --- 監査ログ（利用状況/内容ログ・8-(1) 対応）---
# 監査ログ機能の有効化
AUDIT_ENABLED=true
# 監査ログ DB（チャット履歴とは独立、append-only）
AUDIT_DB_PATH=/data/audit.db
# 入出力の内容を保存するか（false の場合は文字数のみ記録）
AUDIT_STORE_CONTENT=true
# 内容保存の上限文字数
AUDIT_MAX_CONTENT_CHARS=8000
# 保持日数（最低 1095=3年。既定 1825=5年。3年未満を指定しても 1095 に切り上げ）
AUDIT_RETENTION_DAYS=1825

# --- チャット履歴のユーザー別分離（6-(8) 対応）---
# userId 列が無い既存チャットの移管先（メール/sub）。空なら移管せず不可視化。
# LEGACY_CHAT_OWNER=
